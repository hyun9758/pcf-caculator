generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// 제품
model Product {
  id             String   @id @default(cuid())
  name           String
  description    String
  category       String
  functionalUnit String   @map("functional_unit")
  weight         Float
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  activityData ActivityData[]

  @@map("products")
}

/// 배출계수 (버전 이력 추적)
model EmissionFactor {
  id          String  @id @default(cuid())
  name        String
  nameKo      String  @map("name_ko")
  category    String
  unit        String
  co2ePerUnit Float   @map("co2e_per_unit")
  source      String
  region      String
  scope       String
  version     Int     @default(1)
  validFrom   String? @map("valid_from")
  validTo     String? @map("valid_to")

  activityData ActivityData[]

  @@map("emission_factors")
}

/// 활동 데이터
model ActivityData {
  id               String @id @default(cuid())
  productId        String @map("product_id")
  date             String // YYYY-MM-DD
  activityType     String @map("activity_type") // 전기, 원소재, 운송
  lifecycleStage   String @map("lifecycle_stage")
  emissionFactorId String @map("emission_factor_id")
  description      String
  descriptionKo    String @map("description_ko")
  quantity         Float
  unit             String

  product        Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  emissionFactor EmissionFactor @relation(fields: [emissionFactorId], references: [id])

  @@map("activity_data")
}
